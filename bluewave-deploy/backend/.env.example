# OPTION A: Resend (recommended – uses HTTP, no SMTP ports blocked)
# Sign up at resend.com, create API key, add to .env
RESEND_API_KEY=re_xxxx
# For testing use onboarding@resend.dev; for production use verified domain
RESEND_FROM="The Blue Wave <onboarding@resend.dev>"

# OPTION B: SMTP (Hosting2GO etc – may be blocked by firewall/ISP)
SMTP_HOST=server75.hosting2go.nl
SMTP_PORT=465
SMTP_USER=maxmax@zebra-onlinedesign.com
SMTP_PASS=your_password

# Where to send new-subscriber notifications
ADMIN_EMAIL=maxmax@zebra-onlinedesign.com

MAGAZINE_SITE_URL=http://localhost:5176

# URL of the Blue Wave site (for email banner image). Use your production URL when deployed.
SITE_URL=http://localhost:5174
